{
  "name": "@permifyjs/nestjs",
  "version": "0.1.0",
  "description": "NestJS adapter for PermifyJS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nestjs",
    "guard",
    "rbac",
    "permissions",
    "authorization",
    "permifyjs"
  ],
  "author": "Olufemi Samuel contact@permify.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeaddictx10/permifyjs.git",
    "directory": "packages/nestjs"
  },
  "homepage": "https://github.com/codeaddictx10/permifyjs#readme",
  "bugs": {
    "url": "https://github.com/codeaddictx10/permifyjs/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "dependencies": {
    "@permifyjs/core": "workspace:^0.1.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/node": "^20.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  }
}
