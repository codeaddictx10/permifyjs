{
  "name": "@permifyjs/fastify",
  "version": "1.0.0-beta.2",
  "description": "Fastify adapter for PermifyJS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "keywords": [
    "fastify",
    "middleware",
    "rbac",
    "permissions",
    "permifyjs"
  ],
  "author": "Olufemi Samuel contact@permify.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeaddictx10/permifyjs.git",
    "directory": "packages/fastify"
  },
  "homepage": "https://github.com/codeaddictx10/permifyjs#readme",
  "bugs": {
    "url": "https://github.com/codeaddictx10/permifyjs/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@permifyjs/core": "workspace:^1.0.0-beta.1"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "fastify": "^5.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
