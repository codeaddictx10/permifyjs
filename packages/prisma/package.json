{
  "name": "@permifyjs/prisma",
  "version": "0.3.0-beta.0",
  "description": "Prisma adapter for PermifyJS",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "prisma",
    "database",
    "rbac",
    "permissions",
    "authorization",
    "permifyjs"
  ],
  "author": "Olufemi Samuel contact@permify.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeaddictx10/permifyjs.git",
    "directory": "packages/prisma"
  },
  "homepage": "https://github.com/codeaddictx10/permifyjs#readme",
  "bugs": {
    "url": "https://github.com/codeaddictx10/permifyjs/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "dependencies": {
    "@permifyjs/core": "workspace:^0.3.0-beta.0"
  },
  "peerDependencies": {
    "@prisma/client": "^7.6.0"
  },
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "@types/node": "^25.5.0",
    "prisma": "^7.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
