{
  "name": "@permifyjs/core",
  "version": "1.0.0-beta.1",
  "description": "Framework-agnostic RBAC engine for Node.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "permifyjs": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/bin.d.ts",
      "require": "./dist/cli/bin.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsup && node -e \"require('fs-extra').copySync('src/cli/templates','dist/templates')\" && chmod +x dist/bin.js",
    "test": "vitest",
    "dev": "pnpm exec tsup --watch",
    "start": "node ./dist/bin.js"
  },
  "keywords": [
    "rbac",
    "permissions",
    "roles",
    "authorization",
    "access-control",
    "nodejs",
    "typescript"
  ],
  "author": "Olufemi Samuel contact@permify.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeaddictx10/permifyjs.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/codeaddictx10/permifyjs#readme",
  "bugs": {
    "url": "https://github.com/codeaddictx10/permifyjs/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "@vitest/ui": "^4.1.2",
    "tsup": "^8.5.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "handlebars": "^4.7.9",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "typescript": "^6.0.2"
  }
}
