generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}


// ─── permifyjs models ─────────────────────────────────────────────
// Auto-generated by permifyjs init — do not edit manually

model PermifyRole {
  id          String   @id @default(cuid())
  name        String   @unique
  tenantId     String   @default("__permify_global__")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions PermifyRoleHasPermission[]
  models      PermifyModelHasRole[]

  @@map("roles")
}

model PermifyPermission {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles  PermifyRoleHasPermission[]
  models PermifyModelHasPermission[]

  @@map("permissions")
}

model PermifyRoleHasPermission {
  roleId       String
  permissionId String
  tenantId     String   @default("__permify_global__")

  role       PermifyRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission PermifyPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId, tenantId])
  @@map("role_has_permissions")
}

model PermifyModelHasRole {
  modelId   String
  modelType String
  tenantId  String   @default("__permify_global__")
  roleId    String

  role PermifyRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([modelId, modelType, tenantId, roleId])
  @@map("model_has_roles")
}

model PermifyModelHasPermission {
  modelId      String
  modelType    String
  tenantId     String   @default("__permify_global__")
  permissionId String

  permission PermifyPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([modelId, modelType, tenantId, permissionId])
  @@map("model_has_permissions")
}
